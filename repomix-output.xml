                    />
                </div>
                <div>
                    <label className="text-xs text-muted-foreground mb-1 block">Nombre tasa B</label>
                    <input
                        className="input-sistema text-sm mb-2"
                        value={labelB}
                        onChange={(e) => setLabelB(e.target.value)}
