        tipo,
        monto: totalPendiente,
        tipoTarjeta: 'debito',
    });

    const actualizar = (campo: string, valor: any) => {
        const nuevoDatos = { ...datos, [campo]: valor };
        setDatos(nuevoDatos);
        onActualizar(index, nuevoDatos as PagoMetodo);
