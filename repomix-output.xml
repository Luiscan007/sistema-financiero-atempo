    --card: 222.2 84% 4.9%;
    --card-foreground: 210 40% 98%;
    --popover: 222.2 84% 4.9%;
    --popover-foreground: 210 40% 98%;
    --primary: 210 40% 98%;
    --primary-foreground: 222.2 47.4% 11.2%;
    --secondary: 217.2 32.6% 17.5%;
    --secondary-foreground: 210 40% 98%;
    --muted: 217.2 32.6% 17.5%;
    --muted-foreground: 215 20.2% 65.1%;
    --accent: 217.2 32.6% 17.5%;
    --accent-foreground: 210 40% 98%;
    --destructive: 0 62.8% 30.6%;
    --destructive-foreground: 210 40% 98%;
    --border: 217.2 32.6% 17.5%;
    --input: 217.2 32.6% 17.5%;
    --ring: 212.7 26.8% 83.9%;
    --chart-1: 220 70% 50%;
    --chart-2: 160 60% 45%;
    --chart-3: 30 80% 55%;
    --chart-4: 280 65% 60%;
    --chart-5: 340 75% 55%;
  }
}

@layer base {
  * {
    @apply border-border;
  }

  body {
    @apply bg-background text-foreground font-sans antialiased;
    font-family: 'Inter', sans-serif;
  }

  /* Scrollbar personalizado */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  ::-webkit-scrollbar-track {
    background: hsl(222, 47%, 11%);
  }

  ::-webkit-scrollbar-thumb {
    background: hsl(217, 33%, 28%);
    border-radius: 3px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: hsl(217, 91%, 60%);
  }

  /* Selección de texto */
  ::selection {
    background: rgba(59, 130, 246, 0.3);
    color: white;
  }

  /* Fuente monoespaciada para números */
  .font-mono {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
  }
}

/* ============================
   COMPONENTES GLOBALES
   ============================ */
@layer components {

  /* Tarjeta base del sistema */
  .card-sistema {
    @apply bg-card border border-border rounded-xl p-6 shadow-lg;
  }

  /* KPI Cards */
  .kpi-card {
    @apply bg-card border border-border rounded-xl p-5 shadow-lg hover:border-blue-500/50 transition-all duration-300 cursor-default;
    background: linear-gradient(135deg, hsl(222, 47%, 12%) 0%, hsl(222, 47%, 10%) 100%);
  }

  .kpi-card:hover {
    box-shadow: 0 0 20px rgba(59, 130, 246, 0.1);
    transform: translateY(-1px);
  }

  /* Valores positivos (verde) */
  .valor-positivo {
    @apply text-green-400 font-semibold;
  }

  /* Valores negativos (rojo) */
  .valor-negativo {
    @apply text-red-400 font-semibold;
  }

  /* Sidebar */
  .sidebar-link {
    @apply flex items-center gap-3 px-4 py-3 rounded-lg text-muted-foreground hover:text-foreground hover:bg-accent transition-all duration-200 cursor-pointer;
  }

  .sidebar-link.active {
    @apply text-blue-400 bg-blue-500/10 border border-blue-500/20;
  }

  .sidebar-link:hover:not(.active) {
    @apply bg-white/5;
  }

  /* Botón primario */
  .btn-primary {
    @apply bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg font-medium transition-all duration-200 flex items-center gap-2 shadow-lg;
  }

  .btn-primary:hover {
    box-shadow: 0 0 15px rgba(59, 130, 246, 0.4);
    transform: translateY(-1px);
  }

  .btn-secondary {
    @apply bg-white/5 hover:bg-white/10 text-foreground border border-border px-4 py-2 rounded-lg font-medium transition-all duration-200 flex items-center gap-2;
  }

  .btn-success {
    @apply bg-green-600 hover:bg-green-500 text-white px-4 py-2 rounded-lg font-medium transition-all duration-200 flex items-center gap-2 shadow-lg;
  }

  .btn-danger {
    @apply bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg font-medium transition-all duration-200 flex items-center gap-2;
  }

  /* Input del sistema */
  .input-sistema {
    @apply w-full bg-input border border-border rounded-lg px-4 py-2.5 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all duration-200;
  }

  /* Badge */
  .badge {
    @apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium;
  }

  .badge-blue { @apply bg-blue-500/20 text-blue-400 border border-blue-500/30; }
  .badge-green { @apply bg-green-500/20 text-green-400 border border-green-500/30; }
  .badge-red { @apply bg-red-500/20 text-red-400 border border-red-500/30; }
  .badge-yellow { @apply bg-yellow-500/20 text-yellow-400 border border-yellow-500/30; }
  .badge-gray { @apply bg-white/10 text-muted-foreground border border-border; }

  /* Tabla */
  .tabla-sistema {
    @apply w-full;
  }

  .tabla-sistema th {
    @apply text-left text-xs font-semibold text-muted-foreground uppercase tracking-wider px-4 py-3 bg-muted/30 border-b border-border;
  }

  .tabla-sistema td {
    @apply px-4 py-3.5 border-b border-border/50 text-sm;
  }

  .tabla-sistema tr:hover td {
    @apply bg-white/[0.02];
  }

  /* Widget de tasas - top bar */
  .tasa-widget {
    @apply flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-border/50 rounded-lg text-sm font-mono;
  }

  /* Skeleton loader */
  .skeleton {
    @apply bg-muted/60 rounded animate-pulse;
    background: linear-gradient(
      90deg,
      hsl(217, 33%, 15%) 0%,
      hsl(217, 33%, 20%) 50%,
      hsl(217, 33%, 15%) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 2s infinite;
  }

  /* POS - Carrito */
  .pos-item {
    @apply flex items-center justify-between p-3 bg-white/[0.03] border border-border/50 rounded-lg hover:border-blue-500/30 transition-all duration-200;
  }

  /* Brecha alta - parpadear rojo */
  .brecha-alta {
    @apply animate-pulse-rojo text-red-400;
  }

  /* Glassmorphism card */
  .glass-card {
    background: rgba(30, 41, 59, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(148, 163, 184, 0.1);
    @apply rounded-xl shadow-2xl;
  }

  /* Gradiente de fondo para secciones */
  .gradient-section {
    background: radial-gradient(ellipse at 50% 0%, rgba(59, 130, 246, 0.08) 0%, transparent 70%);
  }

  /* Modal overlay */
  .modal-overlay {
    @apply fixed inset-0 bg-black/70 backdrop-blur-sm z-50 flex items-center justify-center p-4;
  }

  /* Número en bolívares - formato venezolano */
  .bolivar-amount {
    @apply font-mono font-semibold tracking-tight;
  }
}

/* ============================
   UTILIDADES ADICIONALES
   ============================ */
@layer utilities {
  /* Gradientes de texto */
  .text-gradient-blue {
    @apply bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent;
  }

  .text-gradient-green {
    @apply bg-gradient-to-r from-green-400 to-emerald-400 bg-clip-text text-transparent;
  }

  /* Glow effects */
  .glow-blue {
    box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
  }

  .glow-green {
    box-shadow: 0 0 20px rgba(34, 197, 94, 0.3);
  }

  .glow-red {
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.3);
  }

  /* Texto truncado */
  .truncate-2 {
