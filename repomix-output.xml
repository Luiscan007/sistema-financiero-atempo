                            onChange={(e) => actualizar('ultimosCuatro', e.target.value)}
                            placeholder="XXXX"
                        />
                    </div>
                    <div>
                        <label className="text-xs text-muted-foreground mb-1 block">N° Aprobación</label>
                        <input
                            type="text"
                            className="input-sistema"
                            value={datos.aprobacion || ''}
